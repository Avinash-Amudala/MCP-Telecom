# MCP-Telecom Environment Configuration
# Copy this file to .env and update with your values

# Path to your devices configuration file
MCP_TELECOM_DEVICES_FILE=devices.yaml

# Logging level (DEBUG, INFO, WARNING, ERROR)
MCP_TELECOM_LOG_LEVEL=INFO

# Audit log file path
MCP_TELECOM_AUDIT_LOG=logs/audit.log

# Connection timeout in seconds
MCP_TELECOM_CONN_TIMEOUT=30

# Maximum concurrent connections
MCP_TELECOM_MAX_CONNECTIONS=10

# Enable/disable command safety checks (true/false)
MCP_TELECOM_SAFETY_MODE=true
